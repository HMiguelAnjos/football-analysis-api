# ───────────────────────────────────────────────────────────────────
# Football Analytics API — variáveis de ambiente
# Copie para .env e preencha. SEM nenhuma chave, a API sobe em modo
# fixtures (dados mock) — bom pra dev/CI. Para dados reais, preencha as
# chaves de provider abaixo.
# ───────────────────────────────────────────────────────────────────

# --- Servidor -------------------------------------------------------
PORT=8000
HOST=127.0.0.1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Modo offline ---------------------------------------------------
# 1 = força fixtures em todos os providers (sobe sem nenhuma chave).
USE_FIXTURES=0

# --- Provider de dados: api-football --------------------------------
# Cadastre-se em https://www.api-football.com (ou via RapidAPI).
FOOTBALL_PROVIDER=api_football
API_FOOTBALL_KEY=
# Se usar via RapidAPI, setar 1 (muda base URL + headers).
API_FOOTBALL_RAPIDAPI=0
# Ligas acompanhadas (IDs api-football). 39=PL,140=LaLiga,135=SerieA,
# 78=Bundesliga,61=Ligue1,71=Brasileirão,2=Champions.
DEFAULT_LEAGUE_IDS=39,140,135,78,61,71,2
# Temporada (ano de início). 2025 = 2025/26.
CURRENT_SEASON=2025

# --- Provider de odds: The Odds API (DESATIVADO por enquanto) -------
# "none" = sem odds (roda só com api-football). As telas de odds ficam
# vazias e o engine de valor não gera recomendações (precisa de odds).
# Para LIGAR depois: ODDS_PROVIDER=the_odds_api + ODDS_API_KEY (the-odds-api.com).
ODDS_PROVIDER=none
ODDS_API_KEY=
ODDS_REGIONS=eu
ODDS_BOOKMAKERS=
ODDS_SPORT_KEYS=soccer_epl,soccer_spain_la_liga,soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_brazil_campeonato,soccer_uefa_champs_league

# --- Provider de xG: understat (opcional) ---------------------------
# "none" (default, usa gols reais como proxy) | "understat" | "fixtures"
XG_PROVIDER=none

# --- Engine de recomendação -----------------------------------------
MIN_EDGE=0.03
MIN_ODD=1.30
MAX_ODD=8.0
MIN_CONFIDENCE=40

# --- Worker de settlement -------------------------------------------
ENABLE_SETTLEMENT_WORKER=1
SETTLEMENT_INTERVAL_SECONDS=900

# --- Cache ----------------------------------------------------------
# Em produção (Railway) aponte para um volume persistente, ex: /data
CACHE_DIR=/tmp

# --- Banco de dados (Postgres) --------------------------------------
DATABASE_URL=postgresql+psycopg2://football:football@localhost:5432/football

# --- Auth / JWT -----------------------------------------------------
# Exige login (JWT) nas rotas. Em DEV, REQUIRE_AUTH=0 libera tudo sem token.
# NUNCA desligue em produção.
REQUIRE_AUTH=1
# TROQUE em produção por uma string longa e aleatória.
JWT_SECRET=dev-secret-change-me-in-prod
JWT_EXPIRE_MINUTES=10080
# Emails promovidos a admin no boot (CSV). Precisam já ter cadastro.
ADMIN_EMAILS=

# --- Email transacional (recuperação de senha) — opcional -----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:5173
